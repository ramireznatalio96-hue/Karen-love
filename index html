# Karen-love
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Karen ❤️</title>

<style>
body {
  margin: 0;
  overflow: hidden;
  background: black;
  color: white;
  font-family: Arial;
}

#title {
  position: absolute;
  top: 40px;
  width: 100%;
  text-align: center;
  font-size: 2.5em;
}

#bottomText {
  position: absolute;
  bottom: 40px;
  width: 100%;
  text-align: center;
  font-size: 1.8em;
}
</style>
</head>

<body>

<div id="title">Karen te quiero mucho</div>
<div id="bottomText">Te quiero ver cada minuto</div>

<button onclick="playMusic()" style="position:absolute;top:10px;left:10px;">
Play Music ❤️
</button>

<audio id="music" loop>
  <source src="https://cdn.pixabay.com/download/audio/2022/03/15/audio_c8b1c3e7b9.mp3">
</audio>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r152/three.min.js"></script>

<script>
function playMusic() {
  document.getElementById("music").play();
}

const renderer = new THREE.WebGLRenderer({ antialias:true });
renderer.setSize(window.innerWidth, window.innerHeight);
document.body.appendChild(renderer.domElement);

const scene = new THREE.Scene();

const camera = new THREE.PerspectiveCamera(70, window.innerWidth/window.innerHeight, 0.1, 100);
camera.position.z = 5;

const light = new THREE.PointLight(0xff0033, 2);
light.position.set(2, 3, 5);
scene.add(light);

const rose = new THREE.Mesh(
  new THREE.SphereGeometry(1, 64, 64),
  new THREE.MeshStandardMaterial({ color: 0xff0033 })
);
scene.add(rose);

const petals = [];
for (let i = 0; i < 25; i++) {
  const p = new THREE.Mesh(
    new THREE.PlaneGeometry(0.2, 0.3),
    new THREE.MeshBasicMaterial({ color: 0xff3366, side: THREE.DoubleSide })
  );

  p.position.set((Math.random()-0.5)*4, Math.random()*3, (Math.random()-0.5)*4);
  p.speed = Math.random()*0.02+0.01;

  scene.add(p);
  petals.push(p);
}

function animate() {
  requestAnimationFrame(animate);

  rose.rotation.y += 0.01;

  petals.forEach(p => {
    p.position.y -= p.speed;
    if (p.position.y < -3) p.position.y = 3;
  });

  renderer.render(scene, camera);
}

animate();
</script>

</body>
</html>
